<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600"
      prefWidth="500"
      spacing="15"
      xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.demo.controllers.VistasClientes.FormularioClienteController">

    <padding>
        <Insets top="20" right="30" bottom="20" left="30"/>
    </padding>

    <!-- TITULO -->
    <Label text="Registrar Cliente"/>

    <Separator/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="12">

            <!-- DATOS CLIENTE -->
            <Label text="Datos del Cliente"/>

            <VBox spacing="5">
                <Label text="Nombre Completo:*"/>
                <TextField fx:id="txtNombre"
                           promptText="Ej: Juan Pérez"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Número de Identificación:*"/>
                <TextField fx:id="txtIdentificacion"
                           promptText="Ej: 1091885608"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Teléfono:*"/>
                <TextField fx:id="txtTelefono"
                           promptText="Ej: 3001234567"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Dirección:*"/>
                <TextField fx:id="txtDireccion"
                           promptText="Ej: Cra 15 #20-30"/>
            </VBox>

        </VBox>
    </ScrollPane>


    <HBox alignment="CENTER" spacing="15">

        <Button text="Guardar"
                defaultButton="true"
                onAction="#guardarCliente"/>

        <Button text="Cancelar"
                onAction="#cancelar"/>

    </HBox>

</VBox>
