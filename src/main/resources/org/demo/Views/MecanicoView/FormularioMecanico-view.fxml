<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600"
      prefWidth="500"
      spacing="15"
      xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.demo.controllers.VistasMecanicos.FormularioMecanicosController">

    <padding>
        <Insets top="20" right="30" bottom="20" left="30"/>
    </padding>


    <Label text="Registrar Mecanico"/>

    <Separator/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="12">


            <Label text="Datos del Mecanico"/>

            <VBox spacing="5">
                <Label text="Nombre Completo:*"/>
                <TextField fx:id="txtNombre"
                           promptText="Ej: Pacho Integral"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Especialiad:*"/>
                <TextField fx:id="txtEspecialidad"
                           promptText="Ej: Palancas"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Numero de Certificacion:*"/>
                <TextField fx:id="txtCertificacion"
                           promptText="Ej: 8694984838"/>
            </VBox>



        </VBox>
    </ScrollPane>


    <HBox alignment="CENTER" spacing="15">

        <Button text="Guardar"
                defaultButton="true"
                onAction="#guardarMecanico"/>

        <Button text="Cancelar"
                onAction="#cancelar"/>

    </HBox>

</VBox>
