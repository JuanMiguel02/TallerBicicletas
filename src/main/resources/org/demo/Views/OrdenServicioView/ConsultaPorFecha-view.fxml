<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="15" styleClass="os-root" stylesheets="@../../styles/ordenServicio.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.demo.viewController.VistaOrdenServicio.ConsultaPorFechaController">

    <!-- TITULO -->
    <Label styleClass="os-title" text="Consulta de órdenes por fecha" />

    <!-- FILTROS -->
    <HBox alignment="CENTER" spacing="10" styleClass="os-actions">

        <Label styleClass="os-label" text="Fecha inicio:" />

        <DatePicker fx:id="dpInicio" styleClass="os-input" />

        <Label styleClass="os-label" text="Fecha fin:" />

        <DatePicker fx:id="dpFin" styleClass="os-input" />

        <Button onAction="#onBuscar" styleClass="os-btn-primary" text="Buscar" />
    </HBox>

    <Button onAction="#onVolver" styleClass="os-btn-primary" text="Volver" />
   <TableView fx:id="tablaOrdenes" styleClass="os-table">
      <columns>
         <TableColumn fx:id="colNumero" prefWidth="100" text="N° Orden" />
         <TableColumn fx:id="colCliente" prefWidth="200" text="Cliente" />
         <TableColumn fx:id="colBicicleta" prefWidth="150" text="Bicicleta" />
         <TableColumn fx:id="colMecanico" prefWidth="150" text="Mecanico" />
         <TableColumn fx:id="colFecha" prefWidth="120" text="Fecha" />
         <TableColumn fx:id="colMotivo" prefWidth="150" text="Motivo" />
         <TableColumn fx:id="colEstado" prefWidth="150" text="Estado" />
         <TableColumn fx:id="colCosto" prefWidth="150" text="Costo" />
      </columns>
   </TableView>

</VBox>
