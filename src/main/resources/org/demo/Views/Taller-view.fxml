<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>

<BorderPane fx:id="root" prefHeight="800" prefWidth="1200" styleClass="main-root" stylesheets="@../styles/taller.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.demo.viewController.TallerController">

    <!-- BARRA SUPERIOR -->
    <top>
        <HBox styleClass="top-bar" BorderPane.alignment="CENTER">
            <Label styleClass="top-title" text="Sistema de Gestión Taller Bicicletas" />
        </HBox>
    </top>

    <!-- MENÚ LATERAL -->
    <left>
        <AnchorPane prefWidth="260" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>

                <Label layoutX="95" layoutY="150" styleClass="sidebar-text" text="Bienvenido," />

                <Label layoutX="75" layoutY="179" styleClass="sidebar-user" text="Pepe" />

                <Label layoutX="130" layoutY="177" styleClass="sidebar-role" text="(admin)" />

                <Line endX="180" layoutX="40" layoutY="220" startX="0" styleClass="sidebar-separator" />

                <!-- Botones del menú -->
                <VBox alignment="TOP_CENTER" layoutY="250" prefHeight="107.0" prefWidth="142.0" spacing="15" styleClass="menu-container">
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Button fx:id="btnInicio" onAction="#mostrarInicio" styleClass="btn-admin" text="Inicio">
                                <HBox.margin>
                                    <Insets left="30.0" />
                                </HBox.margin>
                            </Button>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Button fx:id="btnCliente" onAction="#OnCliente" styleClass="btn-admin" text="Clientes">
                                <HBox.margin>
                                    <Insets left="30.0" />
                                </HBox.margin>
                            </Button>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Button fx:id="btnBicicleta" onAction="#OnBicicleta" styleClass="btn-admin" text="Bicicletas">
                                <HBox.margin>
                                    <Insets left="30.0" />
                                </HBox.margin>
                            </Button>
                        </HBox>

                    </children>
                </VBox>

                <Button fx:id="btnSalir" layoutX="75.0" layoutY="602.0" onAction="#volverLogin" styleClass="btn-admin " text="Salir" />

                <Button fx:id="btnOrdenServicio" layoutX="20.0" layoutY="452.0" onAction="#OnOrdenServicio" styleClass="btn-admin" text="Ordenes de Servicio" />

                <Button fx:id="btnMecanico" layoutX="22.0" layoutY="420.0" onAction="#OnMecanico" prefHeight="14.0" prefWidth="109.0" styleClass="btn-admin" text="Mecanicos" />

                <Button fx:id="btnConsulta" layoutX="22.0" layoutY="496.0" onAction="#OnConsulta" styleClass="btn-admin" text="Consulta por Fecha" />

            </children>
        </AnchorPane>
    </left>

    <!-- CONTENIDO CENTRAL -->
    <center>
        <StackPane fx:id="contenedorCentro" styleClass="center-container" BorderPane.alignment="CENTER">
            <children>

                <!-- VISTA INICIO -->
                <AnchorPane fx:id="vistaInicio" prefHeight="712.0" prefWidth="946.0" styleClass="dashboard-view">
                    <children>

                        <HBox alignment="CENTER" layoutX="32.0" layoutY="40" prefHeight="175.0" prefWidth="958.0" spacing="40" styleClass="stats-container">

                            <children>

                                <!-- Total Bicicletas -->
                                <VBox fx:id="statCard1" alignment="CENTER" prefWidth="300.0" spacing="20.0" styleClass="stat-card">
                                    <Label fx:id="lblTotalUsuarios" styleClass="stat-value" text="0" />
                                    <Label styleClass="stat-label" text="Bicicletas Registradas" />
                                </VBox>

                                <!-- Clientes -->
                                <VBox fx:id="statCard2" alignment="CENTER" prefWidth="300.0" spacing="20.0" styleClass="stat-card">
                                    <Label styleClass="stat-value" text="0" />
                                    <Label styleClass="stat-label" text="Clientes Registrados" />
                                </VBox>

                                <!-- Ordenes -->
                                <VBox fx:id="statCard3" alignment="CENTER" prefWidth="300.0" spacing="20.0" styleClass="stat-card">
                                    <Label styleClass="stat-value" text="0" />
                                    <Label styleClass="stat-label" text="Ordenes Activas" />
                                </VBox>

                            </children>
                        </HBox>

                        <AreaChart fx:id="graficaServicios" layoutY="350" prefHeight="300" prefWidth="800" styleClass="chart-dashboard" title="Servicios Por Mes">
                            <xAxis>
                                <CategoryAxis side="BOTTOM" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis side="LEFT" />
                            </yAxis>
                        </AreaChart>

                    </children>
                </AnchorPane>
            </children>
        </StackPane>
    </center>

    <!-- PIE DE PÁGINA -->
    <bottom>
        <HBox prefHeight="56.0" prefWidth="1250.0" styleClass="bottom-bar" BorderPane.alignment="CENTER" />
    </bottom>

</BorderPane>
