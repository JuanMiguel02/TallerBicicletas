<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600" prefWidth="500" spacing="15" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.demo.viewController.VistasBicicletas.FormularioBicicletasController">

    <padding>
        <Insets bottom="20" left="30" right="30" top="20" />
    </padding>

    <!-- TITULO -->
    <Label text="Registrar Bicicleta" />

    <Separator />

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="12">

            <!-- DATOS CLIENTE -->
            <Label text="Datos de la Bicicleta" />

            <VBox spacing="5">
                <Label text="Marca:*" />
                <TextField fx:id="txtMarca" promptText="Ej: BMW" />
            </VBox>

            <VBox spacing="5">
                <Label text="Tipo:*" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbTipoBicicleta"
                          promptText="Seleccione tipo"
                          GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Color:*" />
                <TextField fx:id="txtColor" promptText="Ej: rojo" />
            </VBox>

            <VBox spacing="5">
                <Label text="Serial:*" />
                <TextField fx:id="txtNumeroSerie" promptText="Ej: 345" />
            </VBox>

            <VBox spacing="5">
                <Label text="Año:*" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <Spinner fx:id="spAnio" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </VBox>

            <VBox spacing="5">
                <Label text="Propietario:*" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <ComboBox fx:id="cmbCliente" promptText="Seleccione cliente" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- BOTONES -->
    <HBox alignment="CENTER" spacing="15">

        <Button defaultButton="true" onAction="#guardarBicicleta" text="Guardar" />

        <Button onAction="#cancelar" text="Cancelar" />

    </HBox>

</VBox>
