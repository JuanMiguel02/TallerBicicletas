<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="os-root" stylesheets="@../../styles/ordenServicio.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.demo.viewController.VistaOrdenServicio.TablaOrdenServicioController">

    <!-- TITULO -->
    <top>
        <VBox spacing="10" styleClass="os-header">
            <padding>
                <Insets bottom="10" left="20" right="20" top="20" />
            </padding>

            <Label styleClass="os-title" text="Historial de Órdenes de Servicio" />

            <Separator styleClass="os-separator" />
        </VBox>
    </top>

    <!-- CONTENIDO -->
    <center>
        <VBox spacing="15" styleClass="os-table-container">
            <padding>
                <Insets bottom="20" left="20" right="20" top="10" />
            </padding>

            <!-- BOTONES -->
            <HBox spacing="10" styleClass="os-actions">

                <Button fx:id="btnNuevaOrden" onAction="#onNuevaOrden" styleClass="os-btn-primary" text="Nueva Orden" />

                <Button fx:id="btnVerDetalle" onAction="#onVerDetalle" styleClass="os-btn-primary" text="Ver Detalle" />
            <Button layoutX="131.0" layoutY="15.0" onAction="#marcarCompletado" styleClass="os-btn-primary" text="Marcar Como Completado" />

                <Button fx:id="btnEliminar" onAction="#onEliminarOrden" styleClass="os-btn-danger" text="Eliminar" />

            </HBox>

                     <!-- TABLA -->
            <TableView fx:id="tablaOrdenes" styleClass="os-table" VBox.vgrow="ALWAYS">

                         <columns>

                             <TableColumn fx:id="colNumero" prefWidth="100" text="N° Orden" />

                             <TableColumn fx:id="colCliente" prefWidth="200" text="Cliente" />

                             <TableColumn fx:id="colBicicleta" prefWidth="150" text="Bicicleta" />
               <TableColumn fx:id="colMecanico" prefWidth="150" text="Mecanico" />

                             <TableColumn fx:id="colFecha" prefWidth="120" text="Fecha" />
               <TableColumn fx:id="colMotivo" prefWidth="150" text="Motivo" />

                             <TableColumn fx:id="colEstado" prefWidth="150" text="Estado" />
               <TableColumn fx:id="colCosto" prefWidth="150" text="Costo" />

                         </columns>

                     </TableView>

        </VBox>
    </center>

</BorderPane>
