<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600"
      prefWidth="500"
      spacing="15"
      xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.demo.controllers.VistasBicicletas.FormularioBicicletasController">

    <padding>
        <Insets top="20" right="30" bottom="20" left="30"/>
    </padding>

    <!-- TITULO -->
    <Label text="Registrar Bicicleta"/>

    <Separator/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="12">

            <!-- DATOS CLIENTE -->
            <Label text="Datos de la Bicicleta"/>

            <VBox spacing="5">
                <Label text="Marca:*"/>
                <TextField fx:id="txtMarca"
                           promptText="Ej: BMW"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Tipo:*"/>
                <TextField fx:id="txtTipo"
                           promptText="Ej: Urbana"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Color:*"/>
                <TextField fx:id="txtColor"
                           promptText="Ej: rojo"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Serial:*"/>
                <TextField fx:id="txtSerial"
                           promptText="Ej: 345"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Año:*"/>
                <TextField fx:id="txtAnio"
                           promptText="Ej: 2006"/>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- BOTONES -->
    <HBox alignment="CENTER" spacing="15">

        <Button text="Guardar"
                defaultButton="true"
                onAction="#guardarBicicleta"/>

        <Button text="Cancelar"
                onAction="#cancelar"/>

    </HBox>

</VBox>
