<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.demo.viewController.VistasBicicletas.TablaBicicletasController">

    <!-- TITULO -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="20" right="20" top="20" />
            </padding>

            <Label text="Gestión de Bicicletas" />

            <Separator />
        </VBox>
    </top>

    <!-- BOTONES -->
    <center>
        <VBox spacing="15">
            <padding>
                <Insets bottom="20" left="20" right="20" top="10" />
            </padding>

            <HBox spacing="10">
                <Button fx:id="btnNuevo" onAction="#onNuevaBicicleta" text="Nueva Bicicleta" />

                <Button fx:id="btnHistorial" onAction="#onHistorialServicio" text="Historial de servicio" />

                <Button fx:id="btnEditar" onAction="#onEditarBicicleta" text="Editar" />

                <Button fx:id="btnEliminar" onAction="#onEliminarBicicleta" text="Eliminar" />
            </HBox>

            <!-- TABLA -->
            <TableView fx:id="tablaBicicletas" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colMarca" prefWidth="200" text="Marca" />

                    <TableColumn fx:id="colTipo" prefWidth="150" text="Tipo" />

                    <TableColumn fx:id="colColor" prefWidth="150" text="Color" />

                    <TableColumn fx:id="colSerial" prefWidth="250" text="Serial" />

                    <TableColumn fx:id="colAnio" prefWidth="150" text="Año" />
               <TableColumn fx:id="colPropietario" prefWidth="150" text="Propietario" />
                </columns>


            </TableView>

        </VBox>
    </center>

</BorderPane>
