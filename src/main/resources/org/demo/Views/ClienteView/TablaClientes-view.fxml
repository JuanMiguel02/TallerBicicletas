<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.demo.viewController.VistasClientes.TablaClientesController">


    <top>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="20" right="20" top="20" />
            </padding>

            <Label text="Gestión de Clientes" />

            <Separator />
        </VBox>
    </top>


    <center>
        <VBox spacing="15">
            <padding>
                <Insets bottom="20" left="20" right="20" top="10" />
            </padding>

            <HBox spacing="10">
                <Button fx:id="btnNuevo" onAction="#onNuevoCliente" text="Nuevo Cliente" />

                <Button fx:id="btnEditar" onAction="#onEditarCliente" text="Editar" />

                <Button fx:id="btnEliminar" onAction="#onEliminarCliente" text="Eliminar" />
            </HBox>


            <TableView fx:id="tablaClientes" VBox.vgrow="ALWAYS">

                <columns>
               <TableColumn fx:id="colId" prefWidth="200" text="Id" />
                    <TableColumn fx:id="colNombre" prefWidth="200" text="Nombre Completo" />

                    <TableColumn fx:id="colIdentificacion" prefWidth="150" text="Identificación" />

                    <TableColumn fx:id="colTelefono" prefWidth="150" text="Teléfono" />

                    <TableColumn fx:id="colDireccion" prefWidth="250" text="Dirección" />
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>
