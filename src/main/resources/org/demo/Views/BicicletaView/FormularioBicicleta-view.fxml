<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600" prefWidth="500" spacing="15" styleClass="form-root" stylesheets="@../../styles/FormularioTablas.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.demo.viewController.VistasBicicletas.FormularioBicicletasController">

    <padding>
        <Insets bottom="20" left="30" right="30" top="20" />
    </padding>

    <!-- TITULO -->
    <Label styleClass="form-title" text="Registrar Bicicleta" />

    <Separator styleClass="form-separator" />

    <ScrollPane fitToWidth="true" styleClass="form-scroll" VBox.vgrow="ALWAYS">

        <VBox spacing="12" styleClass="form-container">

            <!-- DATOS -->
            <Label styleClass="section-title" text="Datos de la Bicicleta" />

            <VBox spacing="5" styleClass="field-group">
                <Label styleClass="field-label" text="Marca:*" />
                <TextField fx:id="txtMarca" promptText="Ej: BMW" styleClass="textfield" />
            </VBox>

            <VBox spacing="5" styleClass="field-group">
                <Label styleClass="field-label" text="Tipo:*" />
                <ComboBox fx:id="cmbTipoBicicleta" promptText="Seleccione tipo" styleClass="combo-box-form" />
            </VBox>

            <VBox spacing="5" styleClass="field-group">
                <Label styleClass="field-label" text="Color:*" />
                <TextField fx:id="txtColor" promptText="Ej: rojo" styleClass="textfield" />
            </VBox>

            <VBox spacing="5" styleClass="field-group">
                <Label styleClass="field-label" text="Serial:*" />
                <TextField fx:id="txtNumeroSerie" promptText="Ej: 345" styleClass="textfield" />
            </VBox>

            <VBox spacing="5" styleClass="field-group">
                <Label styleClass="field-label" text="Año:*" />
                <Spinner fx:id="spAnio" styleClass="spinner-form" />
            </VBox>

            <VBox spacing="5" styleClass="field-group">
                <Label styleClass="field-label" text="Propietario:*" />
                <ComboBox fx:id="cmbCliente" promptText="Seleccione cliente" styleClass="combo-box-form" />
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- BOTONES -->
    <HBox alignment="CENTER" spacing="15" styleClass="form-buttons">

        <Button defaultButton="true" onAction="#guardarBicicleta" styleClass="btn-primary" text="Guardar" />

        <Button onAction="#cancelar" styleClass="btn-secondary" text="Cancelar" />

    </HBox>

</VBox>
