<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.demo.viewController.VistasMecanicos.TablaMecanicosController">


    <top>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="20" right="20" top="20" />
            </padding>

            <Label text="Gestión de Mecanicos" />

            <Separator />
        </VBox>
    </top>


    <center>
        <VBox spacing="15">
            <padding>
                <Insets bottom="20" left="20" right="20" top="10" />
            </padding>

            <HBox spacing="10">
                <Button fx:id="btnNuevo" onAction="#onNuevoMecanico" text="Nuevo Mecanico" />

                <Button fx:id="btnEditar" onAction="#onEditarMecanico" text="Editar" />

                <Button fx:id="btnEliminar" onAction="#onEliminarMecanico" text="Eliminar" />
            </HBox>


            <TableView fx:id="tablaMecanicos" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colCodigoMecanico" prefWidth="145.0" text="Código " />

                    <TableColumn fx:id="colNombreCompleto" prefWidth="202.0" text="Nombre Completo" />

                    <TableColumn fx:id="colDocumento" prefWidth="153.0" text="Documento" />
               <TableColumn fx:id="colTelefono" prefWidth="200" text="Telefono" />
               <TableColumn fx:id="colDireccion" prefWidth="200" text="Dirección" />
               <TableColumn fx:id="colSueldo" prefWidth="150.0" text="Sueldo" />
               <TableColumn fx:id="colEspecialidad" prefWidth="250.0" text="Especialidad" />


                </columns>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>

            </TableView>

        </VBox>
    </center>

</BorderPane>
